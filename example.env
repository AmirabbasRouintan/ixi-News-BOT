# ═══════════════════════════════════════════════════════════
#  ixi News BOT — Environment Configuration
# ═══════════════════════════════════════════════════════════
# Copy this file to main.env and fill in your values:
#   cp example.env main.env
# ═══════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────
#  ⏱ SCHEDULE
# ───────────────────────────────────────────────────────────

# How often the bot fetches & posts news (in minutes).
NEWS_UPDATE_INTERVAL_MINUTES = 20

# Set to "true" to delete existing database and start fresh on next run.
RESET_DATABASE = false


# ───────────────────────────────────────────────────────────
#  🎯 SCORING THRESHOLDS
# ───────────────────────────────────────────────────────────

# Minimum importance score required for a news to be published.
# Higher = fewer but more impactful news.
# Recommended: 7–15
MIN_IMPACT_SCORE = 15

# Maximum number of posts sent per day (across all sources).
MAX_POSTS_PER_DAY = 30


# ───────────────────────────────────────────────────────────
#  🤖 TELEGRAM SETTINGS
# ───────────────────────────────────────────────────────────

# Your bot token from @BotFather on Telegram.
TELEGRAM_BOT_TOKEN = "your_bot_token_here"

# Target channel/chat ID (can be numeric like -1001234567890 or @username).
TELEGRAM_CHANNEL_ID = -1000000000000

# Telegram user ID allowed to use the control panel (0 = disabled).
ADMIN_TELEGRAM_ID = 0

# Enable the Telegram-based admin control panel (true/false).
BOT_PANEL = false

# Optional: separate bot token for the control panel.
# Leave empty to use the same bot as TELEGRAM_BOT_TOKEN.
BOT_PANEL_BOT_TOKEN = ""


# ───────────────────────────────────────────────────────────
#  🗄 DATABASE
# ───────────────────────────────────────────────────────────

# SQLite database file name (stored alongside main.env).
DB_NAME = "news_storage.db"


# ───────────────────────────────────────────────────────────
#  📡 RSS FEED URLS
# ───────────────────────────────────────────────────────────

# CNBC News RSS
CNBC_RSS_URL = "https://www.cnbc.com/id/100003114/device/rss/rss.html"

# Yahoo Finance RSS
YAHOO_RSS_URL = "https://finance.yahoo.com/news/rssindex"

# Reuters World News RSS
REUTERS_RSS_URL = "http://feeds.reuters.com/reuters/worldNews"

# Investing.com RSS (change the number for different categories)
INVESTING_RSS_URL = "https://www.investing.com/rss/news_25.rss"

# ForexFactory Economic Calendar XML
FOREXFACTORY_CALENDAR_URL = "https://nfs.faireconomy.media/ff_calendar_thisweek.xml"


# ───────────────────────────────────────────────────────────
#  🧠 AI SUMMARIZATION (OpenRouter)
# ───────────────────────────────────────────────────────────

# Your OpenRouter API key (get one at https://openrouter.ai/keys).
OPENROUTER_API_KEY = "sk-or-v1-your_api_key_here"

# AI model to use (e.g. openai/gpt-4o-mini, moonshotai/kimi-k2.6:free, google/gemini-2.0-flash-exp).
OPENROUTER_MODEL = "moonshotai/kimi-k2.6:free"

# OpenRouter base URL (do not change unless you use a custom proxy).
OPENROUTER_BASE_URL = "https://openrouter.ai/api/v1"


# ───────────────────────────────────────────────────────────
#  🔑 KEYWORD SCORING
# ───────────────────────────────────────────────────────────

# Each keyword maps to an impact score.
# When a news article title or content matches any keyword,
# that score is added to the article's total importance.
#
# Format: "Keyword": score
# Scores stack — multiple matches = higher total.
#
# Score guide:
#   5 = critical (Fed, FOMC, CPI, GDP, War, Recession)
#   4 = high     (Inflation, Bitcoin, NASDAQ, Sanctions…)
#   3 = medium   (Oil, Gold, Market, Fed members…)
#   2 = low      (Stock tickers, Currencies, Price…)

HIGH_IMPACT_KEYWORDS='{
  "Fed": 5,
  "FOMC": 5,
  "Interest Rate": 5,
  "CPI": 5,
  "GDP": 5,
  "War": 5,
  "Recession": 5,
  "Unemployment": 4,
  "PMI": 4,
  "ADP": 4,
  "Inflation": 4,
  "Sanctions": 4,
  "Bitcoin": 4,
  "Crypto": 4,
  "ECB": 4,
  "NASDAQ": 4,
  "S&P": 4,
  "Gold": 3,
  "Oil": 3,
  "Market": 3,
  "Iran": 3,
  "USD": 2,
  "Euro": 2,
  "AAPL": 2,
  "TSLA": 2,
  "NVDA": 2
}'


# ───────────────────────────────────────────────────────────
#  📊 SOURCE SCORES
# ───────────────────────────────────────────────────────────

# Base score added to every article from a given source.
# Higher = source is prioritized.
#
# Format: "SourceName": score

SOURCE_SCORE='{
  "Yahoo": 3,
  "Reuters": 3,
  "CNBC": 3,
  "Investing.com": 3,
  "ForexFactory": 3
}'
